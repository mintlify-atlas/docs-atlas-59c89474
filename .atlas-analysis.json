  "keyFeatures": [
    "REST API for currency and exchange rate management",
    "Automatic exchange rate updates from Central Bank of Russia",
    "Support for direct, reverse, and cross-rate currency conversions",
    "PostgreSQL database with Entity Framework Core",
    "Clean architecture with separation of concerns",
    "Docker containerization support",
    "Swagger/OpenAPI documentation"
  ],
  "publicApiSurface": [
    "GET /api/Currency - Get all currencies",
    "GET /api/Currency/{searchString} - Search currencies",
    "POST /api/Currency - Create a new currency",
    "GET /api/ExchangeRate - Get all exchange rates",
    "GET /api/ExchangeRate/{searchString} - Search exchange rates",
    "POST /api/ExchangeRate - Create a new exchange rate",
    "PATCH /api/ExchangeRate/{baseCurrencyCode}&{targetCurrencyCode} - Update exchange rate",
    "GET /api/Exchange/from={baseCurrencyCode}&to={targetCurrencyCode}&amount={amount} - Convert currency"
  ]
}
